{
  "name": "leave-mgmt-backend",
  "version": "1.0.0",
  "description": "Leave Request Management System - Backend",
  "main": "server.js",
  "scripts": {
    "start":    "node server.js",
    "dev":      "nodemon server.js",
    "test":     "jest --runInBand --forceExit --detectOpenHandles",
    "test:ci":  "jest --runInBand --forceExit --detectOpenHandles --ci --coverage",
    "lint":     "echo 'No linter configured'"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "verbose": true
  },
  "dependencies": {
    "bcryptjs":             "^2.4.3",
    "cors":                 "^2.8.5",
    "dotenv":               "^16.0.3",
    "express":              "^4.18.2",
    "express-async-errors": "^3.1.1",
    "jsonwebtoken":         "^9.0.0",
    "mongoose":             "^7.3.1",
    "morgan":               "^1.10.0"
  },
  "devDependencies": {
    "jest":      "^29.5.0",
    "nodemon":   "^3.0.1",
    "supertest": "^6.3.3"
  }
}
